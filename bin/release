#!/usr/bin/env ruby
# frozen_string_literal: true

# Usage: ruby script/release.rb [patch|minor|major]
# Bumps the version, commits, tags, and pushes to trigger the release workflow.

Dir.chdir(File.expand_path("..", __dir__))
require_relative "../lib/readability/version"

LEVEL = ARGV[0]

unless %w[patch minor major].include?(LEVEL)
  abort "Usage: ruby script/release.rb [patch|minor|major]"
end

current = Readability::VERSION
major, minor, patch = current.split(".").map(&:to_i)

case LEVEL
when "patch" then patch += 1
when "minor" then minor += 1; patch = 0
when "major" then major += 1; minor = 0; patch = 0
end

new_version = "#{major}.#{minor}.#{patch}"
version_file = "lib/readability/version.rb"

puts "#{current} → #{new_version}"

File.write(version_file, <<~RUBY)
  # frozen_string_literal: true

  module Readability
    VERSION = "#{new_version}"
  end
RUBY

system("git add #{version_file}") || abort("git add failed")
system("git commit -m 'Release v#{new_version}'") || abort("git commit failed")
system("git tag v#{new_version}") || abort("git tag failed")
system("git push && git push origin v#{new_version}") || abort("git push failed")

puts "Released v#{new_version}"
