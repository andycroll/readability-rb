#!/usr/bin/env ruby
# frozen_string_literal: true

# Usage: bin/release [patch|minor|major]
# Bumps the version, commits, tags, and pushes to trigger the release workflow.

require "net/http"
require "json"

Dir.chdir(File.expand_path("..", __dir__))
require_relative "../lib/readability/version"

LEVEL = ARGV[0]

unless %w[patch minor major].include?(LEVEL)
  abort "Usage: bin/release [patch|minor|major]"
end

# Check what's actually published on RubyGems to prevent releasing an older version
begin
  response = Net::HTTP.get(URI("https://rubygems.org/api/v1/gems/readability-rb.json"))
  published = JSON.parse(response)["version"]
rescue
  published = nil
end

local = Readability::VERSION

if published && Gem::Version.new(local) < Gem::Version.new(published)
  warn "Local version (#{local}) is behind published version (#{published})."
  warn "Bumping local to match #{published} before applying #{LEVEL} bump."
  local = published
end

major, minor, patch = local.split(".").map(&:to_i)

case LEVEL
when "patch" then patch += 1
when "minor" then minor += 1; patch = 0
when "major" then major += 1; minor = 0; patch = 0
end

new_version = "#{major}.#{minor}.#{patch}"

if published && Gem::Version.new(new_version) <= Gem::Version.new(published)
  abort "Refusing to release #{new_version} — not greater than published #{published}"
end

version_file = "lib/readability/version.rb"

puts "#{Readability::VERSION} → #{new_version} (published: #{published || 'unknown'})"

File.write(version_file, <<~RUBY)
  # frozen_string_literal: true

  module Readability
    VERSION = "#{new_version}"
  end
RUBY

system("git add #{version_file}") || abort("git add failed")
system("git commit -m 'Release v#{new_version}'") || abort("git commit failed")
system("git tag v#{new_version}") || abort("git tag failed")
system("git push && git push origin v#{new_version}") || abort("git push failed")

puts "Released v#{new_version}"
